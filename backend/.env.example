# CleanCore AI Backend
SAP_ASHOST=
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=
SAP_PASSWD=
SAP_LANG=EN
SAP_SAPROUTER=

# Required for live SAP RFC via pyrfc.
# Download SAP NW RFC SDK 7.50 from SAP Support Portal and point this to its root folder.
# Use forward slashes or escaped backslashes in .env so \n is not parsed as a newline.
# Example on Windows: SAPNWRFC_HOME=C:/nwrfcsdk
SAPNWRFC_HOME=
SAP_CONNECT_TIMEOUT_SECONDS=30
SAP_RFC_CALL_TIMEOUT_SECONDS=60

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

CONFIDENCE_THRESHOLD=0.85
DEBUG=true
